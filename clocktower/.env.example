# Clocktower Environment Variables
#
# Copy this file to .env and populate all values before starting the server.
# Never commit the populated .env. This file (names + descriptions only) is
# safe to commit and check in.
#
# Sections: Core DB, Auth tokens, Embedding, Integrations (optional personal-OS)

# ============================================================
# DATABASE
# ============================================================

# Full Postgres connection string. Must point at a Postgres 14+ instance
# with pgvector installed. Example: postgres://user:pass@host:5432/clocktower
DATABASE_URL=<PLACEHOLDER>

# Optional: separate connection string for test runs. If absent, tests use
# DATABASE_URL with a schema-namespaced prefix.
TEST_DATABASE_URL=<PLACEHOLDER>

# ============================================================
# SERVER
# ============================================================

# Port the HTTP MCP server listens on. Default: 3000
CLOCKTOWER_PORT=3000

# Public-facing URL of this server (without trailing slash). Used in MCP
# capability advertisement so remote clients can self-discover the endpoint.
# Example: https://clocktower.yourdomain.com
CLOCKTOWER_PUBLIC_URL=<PLACEHOLDER>

# Comma-separated list of allowed CORS origins for the HTTP transport.
# Leave blank to disallow cross-origin requests.
CLOCKTOWER_CORS_ORIGINS=

# Statement timeout (milliseconds) applied to every DB connection.
# Prevents runaway queries. Default: 30000 (30s). Raise for batch embedding.
CLOCKTOWER_STATEMENT_TIMEOUT_MS=30000

# ============================================================
# AUTH TOKENS
# ============================================================
# Tokens are compared at constant time. Use long random strings (>= 32 chars).
# Generate with: openssl rand -hex 32

# Admin/full token: read + write + admin tier. Used by local stdio and
# trusted server-side hooks. Treat like a root password.
CLOCKTOWER_TOKEN=<PLACEHOLDER>

# Write token: read + write tier. Used by most dispatched agents.
CLOCKTOWER_TOKEN_WRITE=<PLACEHOLDER>

# Read-only token: read tier only. Safe to share with untrusted or
# sandboxed consumers.
CLOCKTOWER_TOKEN_READ=<PLACEHOLDER>

# Staging token: write-tier but scoped to the staging workspace.
# Huginn (gatherer agent) holds this; Muninn (curator) holds the write token.
# Lets Huginn deposit without being able to touch live knowledge.
CLOCKTOWER_TOKEN_STAGING=<PLACEHOLDER>

# ============================================================
# EMBEDDING
# ============================================================
# STANDARD: Google Gemini, 768 dimensions.
# All tables that join os_embeddings must use this same model.
# Do NOT mix providers; cross-corpus semantic search silently degrades.

# Gemini API key. Required for embedding generation and semantic search.
GEMINI_API_KEY=<PLACEHOLDER>

# Google API key (alternative/additional; some Gemini SDK paths use this).
# Often the same value as GEMINI_API_KEY.
GOOGLE_API_KEY=<PLACEHOLDER>

# Embedding server port (if running the embedding worker as a separate process)
EMBED_PORT=3001

# Internal URL of the embedding worker, used by the MCP server to call it.
# Example: http://localhost:3001
EMBED_URL=<PLACEHOLDER>

# ============================================================
# OPTIONAL: PERSONAL OS INTEGRATIONS
# ============================================================
# Set CLOCKTOWER_PERSONAL_OS=1 to enable personal-OS watchers and tools.
# Leave blank or set to 0 to run in "project memory only" mode (default for
# new installs). The schema supports both; the watchers are what need these.

CLOCKTOWER_PERSONAL_OS=0

# Path to the local brain (file-based knowledge repo).
# Example: /Users/yourname/brain
CLOCKTOWER_OBSIDIAN_VAULT=<PLACEHOLDER>

# ============================================================
# OPTIONAL: TELEGRAM INTEGRATION
# ============================================================
# Required only if you want Telegram thread retrieval tools.

TELEGRAM_BOT_TOKEN=<PLACEHOLDER>
TELEGRAM_CHAT_ID=<PLACEHOLDER>

# ============================================================
# OPTIONAL: WEBHOOK SIGNING
# ============================================================
# Base secret for HMAC verification of incoming webhooks.
# Individual routes can derive per-route secrets from this base.
CLOCKTOWER_WEBHOOK_SECRET=<PLACEHOLDER>

# ============================================================
# OPTIONAL: GMAIL / EMAIL PERSONAL OS
# ============================================================
# Profile index for multi-account Gmail watchers (personal OS only).
# Format: comma-separated account slugs in order.
# Example: personal,work,alias1
CLOCKTOWER_GMAIL_PROFILE_INDEX=<PLACEHOLDER>

# ============================================================
# OPTIONAL: OPENAI (secondary embedding space only)
# ============================================================
# Only needed if you maintain a secondary 1536-dimension embedding table
# (os_embeddings_openai_1536) for a specific non-Gemini corpus.
# Do NOT use for the primary os_embeddings table.
OPENAI_API_KEY=<PLACEHOLDER>
